<mujoco model="pick_place">
  <compiler angle="radian" coordinate="local"/>
  
  <option timestep="0.002" gravity="0 0 -9.81"/>
  
  <visual>
    <global offwidth="224" offheight="224"/>
  </visual>
  
  <asset>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2"/>
  </asset>
  
  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" diffuse="1 1 1"/>
    <camera name="fixed" pos="0.8 0.8 0.8" xyaxes="-1 1 0 -0.5 -0.5 1"/>
    <geom name="floor" type="plane" size="2 2 .1" material="grid"/>
    
    <!-- Table -->
    <body name="table" pos="0.5 0 0.2">
      <geom type="box" size="0.3 0.3 0.2" rgba="0.8 0.6 0.4 1"/>
    </body>
    
    <!-- Simple 3-DOF arm -->
    <body name="base" pos="0 0 0.4">
      <geom type="cylinder" size="0.05 0.1" rgba="0.7 0.7 0.7 1"/>
      <joint name="joint0" type="hinge" axis="0 0 1" range="-3.14 3.14" damping="1"/>
      
      <body name="link1" pos="0 0 0.1">
        <geom type="capsule" fromto="0 0 0 0.3 0 0" size="0.03" rgba="0.5 0.5 0.8 1"/>
        <joint name="joint1" type="hinge" axis="0 1 0" range="-1.57 1.57" damping="1"/>
        
        <body name="link2" pos="0.3 0 0">
          <geom type="capsule" fromto="0 0 0 0.3 0 0" size="0.03" rgba="0.5 0.8 0.5 1"/>
          <joint name="joint2" type="hinge" axis="0 1 0" range="-1.57 1.57" damping="1"/>
          
          <body name="ee" pos="0.3 0 0">
            <site name="ee_site" pos="0 0 0" size="0.02"/>
            <geom type="sphere" size="0.04" rgba="0.8 0.2 0.2 1"/>
          </body>
        </body>
      </body>
    </body>
    
    <!-- Object to manipulate -->
    <body name="object" pos="0.5 0 0.42">
      <joint type="free"/>
      <geom name="object_geom" type="box" size="0.03 0.03 0.03" rgba="1 0.5 0 1" mass="0.1"/>
    </body>
  </worldbody>
  
  <actuator>
    <position name="act0" joint="joint0" kp="10" ctrlrange="-3.14 3.14"/>
    <position name="act1" joint="joint1" kp="10" ctrlrange="-1.57 1.57"/>
    <position name="act2" joint="joint2" kp="10" ctrlrange="-1.57 1.57"/>
  </actuator>
</mujoco>
